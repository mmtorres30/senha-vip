with open('index.html', 'r', encoding='utf-8') as f:
    content = f.read()

old1 = """  .logo-badge{
    display:inline-flex; align-items:center; justify-content:center;
    margin:0 auto 18px; max-width:260px;
  }
  .logo-badge img{
    display:block; width:100%; height:auto; max-height:46px; object-fit:contain;
    filter:invert(1) brightness(1.6) contrast(0.92);
    opacity:0.92;
  }"""

new1 = """  .logo-badge{
    display:inline-flex; align-items:center; justify-content:center;
    margin:0 auto 18px;
  }
  .logo-mask{
    width:230px; height:56px;
    background-color:var(--gold-bright);
    -webkit-mask-repeat:no-repeat; mask-repeat:no-repeat;
    -webkit-mask-position:center; mask-position:center;
    -webkit-mask-size:contain; mask-size:contain;
  }"""

content = content.replace(old1, new1)

content = content.replace(
    ".topbar .logo-badge img{max-height:26px;}",
    ".topbar .logo-mask{width:112px; height:27px;}"
)
content = content.replace(
    ".tv-brand .logo-badge img{max-height:34px;}",
    ".tv-brand .logo-mask{width:150px; height:37px;}"
)

old_js = """function logoBadgeHtml(extraClass){
  return `<div class="logo-badge ${extraClass||''}" id="logoBadge_${extraClass||'x'}">
    <img src="${LOGO_URL}" alt="Logo" onerror="this.closest('.logo-badge').style.display='none'; this.closest('.logo-badge').nextElementSibling.style.display='flex';">
  </div>
  <div class="crest-fallback">A</div>`;
}"""

new_js = """function logoBadgeHtml(extraClass){
  return `<div class="logo-badge ${extraClass||''}" id="logoBadge_${extraClass||'x'}">
    <div class="logo-mask" style="-webkit-mask-image:url('${LOGO_URL}'); mask-image:url('${LOGO_URL}');"></div>
    <img src="${LOGO_URL}" alt="Logo" style="display:none;" onerror="const b=this.closest('.logo-badge'); b.style.display='none'; b.nextElementSibling.style.display='flex';">
  </div>
  <div class="crest-fallback">A</div>`;
}"""

content = content.replace(old_js, new_js)

with open('index.html', 'w', encoding='utf-8') as f:
    f.write(content)

print("Substituições feitas.")
EOF
